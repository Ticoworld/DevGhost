{
  "name": "devghost",
  "displayName": "DevGhost: Build-in-Public",
  "description": "Cloud-first VS Code extension that watches real coding activity and suggests build-in-public drafts for review. Review-first. Never posts automatically.",
  "version": "3.4.5",
  "preview": true,
  "publisher": "ticoworld",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ticoworld/DevGhost"
  },
  "bugs": {
    "url": "https://github.com/Ticoworld/DevGhost/issues"
  },
  "homepage": "https://github.com/Ticoworld/DevGhost",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "build in public",
    "developer diary",
    "AI drafting",
    "commit logger",
    "developer blog",
    "cloud",
    "cloud-first",
    "review-first",
    "gemini",
    "twitter",
    "x"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "DevGhost",
      "properties": {
        "devghost.deepWorkMinutes": {
          "type": "number",
          "default": 90,
          "minimum": 15,
          "description": "Minutes of active coding before DevGhost considers a session deep work."
        },
        "devghost.cloudApiBaseUrl": {
          "type": "string",
          "default": "https://cloud-ten-steel.vercel.app",
          "description": "Cloud backend URL used by DevGhost Cloud."
        }
      }
    },
    "commands": [
      {
        "command": "devghost.initialize",
        "title": "DevGhost: Edit Project Details"
      },
      {
        "command": "devghost.setFocus",
        "title": "DevGhost: Set Focus"
      },
      {
        "command": "devghost.iWon",
        "title": "DevGhost: Draft a Win (Legacy)"
      },
      {
        "command": "devghost.showLogs",
        "title": "DevGhost: View Logs"
      },
      {
        "command": "devghost.showLastPostDecision",
        "title": "DevGhost: Show Last Post Decision"
      },
      {
        "command": "devghost.privacy",
        "title": "DevGhost: Privacy & Data Use"
      },
      {
        "command": "devghost.setApiKey",
        "title": "DevGhost: Add AI Key (Legacy)"
      },
      {
        "command": "devghost.clearApiKey",
        "title": "DevGhost: Clear AI Key (Legacy)"
      },
      {
        "command": "devghost.pause",
        "title": "DevGhost: Pause Suggestions"
      },
      {
        "command": "devghost.resume",
        "title": "DevGhost: Resume Suggestions"
      },
      {
        "command": "devghost.resetProjectContext",
        "title": "DevGhost: Reset Project Context"
      },
      {
        "command": "devghost.resetRecentActivity",
        "title": "DevGhost: Reset Recent Activity"
      },
      {
        "command": "devghost.shareGrind",
        "title": "DevGhost: Draft From Recent Work (Legacy)"
      },
      {
        "command": "devghost.cloudDraft",
        "title": "DevGhost: Write a Post Now"
      },
      {
        "command": "devghost.checkAiConnection",
        "title": "DevGhost: Check AI Setup (Legacy)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "devghost.setApiKey",
          "when": "false"
        },
        {
          "command": "devghost.clearApiKey",
          "when": "false"
        },
        {
          "command": "devghost.checkAiConnection",
          "when": "false"
        },
        {
          "command": "devghost.iWon",
          "when": "false"
        },
        {
          "command": "devghost.shareGrind",
          "when": "false"
        },
        {
          "command": "devghost.resetProjectContext",
          "when": "false"
        },
        {
          "command": "devghost.resetRecentActivity",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "clean": "powershell -Command \"if (Test-Path out) { Remove-Item -Path out -Recurse -Force }\"",
    "package": "npm run clean && npm run compile && npx @vscode/vsce package",
    "release": "node scripts/release-and-install.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "shiki": "^1.29.2"
  }
}
